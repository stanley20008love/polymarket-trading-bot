# ============================================
# Polymarket 量化交易系统 V2 - 配置文件
# 基于对250万钱包真实数据的分析升级
# 关键修正：真实手续费模型、更严格风控、新策略
# ============================================
# cp .env.example .env

# ===== 钱包配置 (必填) =====
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address_here
POLYMARKET_FUNDER_ADDRESS=0x_your_funder_address_here
SIGNATURE_TYPE=0

# ===== 资金配置 =====
INITIAL_CAPITAL=100
MAX_CAPITAL=1000
TRADE_SIZE_PERCENT=8
MIN_TRADE_SIZE=5
MAX_POSITIONS=3

# ===== 风控 V2（更严格 - 84%亏损者的教训）=====
STOP_LOSS_PERCENT=3
TAKE_PROFIT_PERCENT=8
DAILY_LOSS_LIMIT=1.5
WEEKLY_LOSS_LIMIT=5

# ===== 策略开关 =====
# 单市场YES+NO套利（几乎不存在，保留扫描）
ENABLE_ARBITRAGE=true
# V2新增：多市场互斥套利（negRisk事件，实测确认有空间）
ENABLE_MULTI_MARKET_ARB=true
# 均值回归（极端价格下注）
ENABLE_MEAN_REVERSION=true
# 事件驱动（价格异动反转）
ENABLE_EVENT_DRIVEN=true
# V2新增：地缘政治0手续费优先（最适合100U）
ENABLE_ZERO_FEE=true
# 跟单（需指定目标钱包）
ENABLE_COPY_TRADING=false

# ===== 套利参数 =====
ARB_MIN_SPREAD=1.5
# V2新增：多市场套利最小偏离（%）
MULTI_ARB_MIN_GAP=2.0

# ===== 均值回归 =====
MEAN_REV_LOW_THRESHOLD=0.10
MEAN_REV_HIGH_THRESHOLD=0.90
MEAN_REV_MIN_VOLUME=50000

# ===== 0手续费策略 =====
ZERO_FEE_MIN_VOLUME=100000
ZERO_FEE_MIN_LIQUIDITY=10000

# ===== 事件驱动 =====
EVENT_MIN_VOLUME_24H=100000
EVENT_PRICE_CHANGE_THRESHOLD=10

# ===== 跟单 =====
COPY_TARGET_ADDRESS=
COPY_TRADE_AMOUNT=5

# ===== 安全 =====
DRY_RUN=true

# ===== 通知 =====
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 运行 =====
SCAN_INTERVAL=20
LOG_LEVEL=INFO

# ===== V2 手续费表参考（硬编码在config.py中，此处仅供参考）=====
# fee = shares × feeRate × price × (1-price)
# 地缘政治: 0% | 体育: 3% | 政治/金融: 4% | 加密: 7%
# Maker永远0手续费 + 可获20-25%返佣
