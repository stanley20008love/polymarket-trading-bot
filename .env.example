# ============================================
# Polymarket 量化交易系统 - 配置文件
# ============================================
# 复制此文件为 .env 并填入你的实际值
# cp .env.example .env

# ===== 钱包配置 (必填) =====
# 你的 Polygon 钱包私钥 (0x开头的64位十六进制)
# 获取方式: Polymarket → Settings → Export Private Key
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# 你的钱包地址 (0x开头的42位)
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address_here

# Funder地址 (如果你用Email/Magic登录, 这是你Polymarket账户页面显示的Proxy地址)
# 如果你用浏览器钱包直接登录, 填你的钱包地址即可
POLYMARKET_FUNDER_ADDRESS=0x_your_funder_address_here

# ===== 签名类型 =====
# 0 = EOA钱包 (MetaMask等浏览器钱包)
# 1 = Email/Magic登录的代理钱包
# 2 = 多签钱包
SIGNATURE_TYPE=0

# ===== 资金配置 =====
# 初始资金 (USDC)
INITIAL_CAPITAL=100
# 最大资金上限 (盈利后可逐步提升)
MAX_CAPITAL=1000
# 单笔交易占资金比例 (%)
TRADE_SIZE_PERCENT=10
# 最小单笔交易金额 (USDC) - Polymarket最小下单约5U
MIN_TRADE_SIZE=5
# 最大同时持仓数
MAX_POSITIONS=3

# ===== 风控参数 =====
# 单笔止损比例 (%)
STOP_LOSS_PERCENT=5
# 单笔止盈比例 (%)
TAKE_PROFIT_PERCENT=15
# 日最大亏损比例 (%)
DAILY_LOSS_LIMIT=3
# 周最大亏损比例 (%)
WEEKLY_LOSS_LIMIT=8

# ===== 策略开关 =====
# YES+NO 套利策略
ENABLE_ARBITRAGE=true
# 均值回归策略 (极端价格反转)
ENABLE_MEAN_REVERSION=true
# 事件驱动策略 (高成交量+价格异动)
ENABLE_EVENT_DRIVEN=true
# 跟单策略 (监控指定钱包)
ENABLE_COPY_TRADING=false

# ===== 套利策略参数 =====
# 最小套利空间 (扣除手续费后, %)
ARB_MIN_SPREAD=1.5
# YES+NO总价格超过此值不套利
ARB_MAX_TOTAL_PRICE=0.985

# ===== 均值回归参数 =====
# 价格低于此值考虑买入YES (极度低估)
MEAN_REV_LOW_THRESHOLD=0.10
# 价格高于此值考虑买入NO (极度高估)
MEAN_REV_HIGH_THRESHOLD=0.90
# 最小成交量要求 (USDC)
MEAN_REV_MIN_VOLUME=50000

# ===== 事件驱动参数 =====
# 24小时成交量阈值
EVENT_MIN_VOLUME_24H=100000
# 1小时价格变化阈值 (%)
EVENT_PRICE_CHANGE_THRESHOLD=10

# ===== 跟单策略参数 =====
# 监控的目标钱包地址
COPY_TARGET_ADDRESS=
# 跟单金额 (USDC)
COPY_TRADE_AMOUNT=5

# ===== 安全配置 =====
# DRY_RUN=true = 模拟模式, 不下真单
# DRY_RUN=false = 实盘模式, 会花真钱!
DRY_RUN=true

# Discord通知 (可选)
DISCORD_WEBHOOK=

# Telegram通知 (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 运行配置 =====
# 扫描间隔 (秒)
SCAN_INTERVAL=30
# 日志级别 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
